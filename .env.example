# ─────────────────────────────────────────────────────────────
# MockMate AI — ONE shared env for BOTH client and server.
# Copy this file to .env:   cp .env.example .env
#
# Only VITE_* variables are exposed to the browser bundle by Vite.
# Everything else stays server-side, so secrets here are safe.
# ─────────────────────────────────────────────────────────────

# ---- Server ----
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
MONGODB_URI=mongodb://localhost:27017/mockmate
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# AI questions + grading. Blank = offline mode (uses the seeded question bank).
# Get a free key at https://aistudio.google.com/apikey and paste it below.
GEMINI_API_KEY=
# Optional — override the model if the default is ever retired (e.g. gemini-2.0-flash).
GEMINI_MODEL=gemini-2.5-flash

# ---- Client (browser-exposed) ----
VITE_API_URL=http://localhost:5000/api
