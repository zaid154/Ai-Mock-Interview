# ─────────────────────────────────────────────────────────────
# MockMate AI — ONE shared env for BOTH client and server.
# Copy this file to .env:   cp .env.example .env
#
# Only VITE_* variables are exposed to the browser bundle by Vite.
# Everything else stays server-side, so secrets here are safe.
# ─────────────────────────────────────────────────────────────

# ---- Server ----
PORT=5050
NODE_ENV=development
# CORS origin for the frontend. Leave BLANK in same-origin production.
CLIENT_URL=http://localhost:5174

# MongoDB connection string. NOTE: the variable is MONGODB_URI (not MONGO_URI).
MONGODB_URI=mongodb://localhost:27017/mockmate

# ---- Auth ----
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# ---- Default admin (created/updated by `npm run seed`) ----
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@mockmate.com
ADMIN_PASSWORD=Admin@123

# ---- Gemini AI ----
# One key: GEMINI_API_KEY. Multiple keys (auto-fallback): comma-separated in
# GEMINI_API_KEYS. You can also add/rotate keys later in the admin panel.
# Blank = offline mode for "questions" mode; "quiz" mode needs a working key.
GEMINI_API_KEY=
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-2.5-flash

# ---- Email / OTP (optional) ----
# If blank, OTP codes are printed to the server console instead of emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ---- Client (browser-exposed) ----
VITE_API_URL=http://localhost:5050/api
